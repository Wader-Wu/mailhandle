{
  "default_sync_period": "last_2days",
  "llm_model": "gpt-5.4-mini",
  "llm_failure_mode": "abort",
  "default_priority": "low",
  "suppress_low_priority_notifications": true,
  "collapse_similar_emails": true,
  "owner_aliases": [
    "wader"
  ],
  "manager_senders": [
    "Bin Tan <Bin.Tan@lumentum.com>"
  ],
  "greeting_terms": [
    "hi",
    "hello",
    "dear",
    "good morning",
    "good afternoon",
    "good evening"
  ],
  "rules": [
    {
      "name": "Direct Greeting In To",
      "priority": "high",
      "attention_flags_any": [
        "owner_greeted"
      ]
    },
    {
      "name": "Owner Mentioned With At",
      "priority": "high",
      "attention_flags_any": [
        "owner_tagged"
      ]
    },
    {
      "name": "Manager Sender",
      "priority": "high",
      "sender_matches_manager": true
    },
    {
      "name": "Agile Approval Request",
      "priority": "high",
      "body_contains_any": [
        "need your approval",
        "your approval",
        "approval required",
        "please approve"
      ],
      "sender_contains_any": [
        "agile"
      ]
    },
    {
      "name": "Owner In To",
      "priority": "medium",
      "attention_flags_any": [
        "owner_in_to"
      ]
    },
    {
      "name": "Owner In Cc",
      "priority": "low",
      "attention_flags_any": [
        "owner_in_cc"
      ]
    },
    {
      "name": "Urgent Subject",
      "priority": "high",
      "subject_contains_any": [
        "urgent",
        "asap",
        "action required",
        "immediately"
      ]
    },
    {
      "name": "High Importance",
      "priority": "high",
      "importance": [
        "high"
      ]
    },
    {
      "name": "Zhuque Work",
      "priority": "high",
      "subject_contains_any": [
        "zhuque"
      ]
    },
    {
      "name": "Notifications Low",
      "priority": "low",
      "subject_contains_any": [
        "notification",
        "newsletter",
        "digest"
      ],
      "sender_contains_any": [
        "noreply",
        "notification",
        "updates.miro.com"
      ]
    }
  ]
}
