# Optional. On native Windows, the skill auto-detects the current interpreter.
# Set this only when Outlook must be reached via a specific Windows Python or when debugging from WSL.
WINDOWS_PYTHON_EXE=C:\Users\your-user\AppData\Local\Programs\Python\Python310\python.exe
# Optional. Override the auto-detected mailbox owner used by priority rules.
MAIL_OWNER_EMAIL=your.name@company.com
MAIL_OWNER_NAME=Your Name
# LLM model selection now lives in scripts\priority_rules.json through llm_model.
